# --- Database ---
# Used by backend AND MCP servers (student-db, counselor-alerts)
# Docker: use service name "postgres" instead of "localhost"
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexusai

# --- Security ---
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The app will REFUSE to start if this is left as the example value.
SECRET_KEY=REPLACE_ME_generate_with_python_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Ollama (remote shared server) ---
OLLAMA_BASE_URL=http://10.1.76.234:11434
OLLAMA_MODEL=gpt-oss

# --- Anthropic (Claude Haiku fallback) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LinkedIn MCP (job market data) ---
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# --- MCP Server URLs (defaults for local docker-compose) ---
MCP_STUDENT_DB_URL=http://localhost:9001
MCP_JOB_MARKET_URL=http://localhost:9002
MCP_RESOURCE_RAG_URL=http://localhost:9003
MCP_COUNSELOR_ALERTS_URL=http://localhost:9004

# --- CORS ---
FRONTEND_URL=http://localhost:3000
